# pnpm / npm / yarn
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Next.js (palbaker-ui)
# ============================================================
palbaker-ui/.next/
palbaker-ui/out/
palbaker-ui/build/
palbaker-ui/coverage/
